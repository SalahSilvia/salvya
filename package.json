{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/create-local-env.mjs && node scripts/copy-profiles.mjs",
    "prebuild": "node scripts/create-local-env.mjs && node scripts/copy-profiles.mjs",
    "setup:env": "node scripts/create-local-env.mjs",
    "clean": "node scripts/clean-build-cache.mjs",
    "dev:stop": "node scripts/stop-dev-servers.mjs",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "dev:clean": "node scripts/stop-dev-servers.mjs && node scripts/clean-build-cache.mjs && next dev --webpack",
    "build": "next build",
    "build:clean": "node scripts/clean-build-cache.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "copy-profiles": "node scripts/copy-profiles.mjs",
    "db:bundle": "node scripts/supabase/bundle-migrations.mjs",
    "db:verify": "node scripts/verify-supabase-schema.mjs",
    "validate:production-env": "node scripts/validate-production-env.mjs",
    "catalog:sync": "node scripts/sync-catalog.mjs",
    "blogs:sync": "node scripts/sync-blogs.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.49.8",
    "framer-motion": "^12.38.0",
    "jsbarcode": "^3.12.3",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
